---
import Layout from "../layouts/MainLayout.astro";
import { getPageTranslations } from "../lib/i18n/index";

const translations = {
  bg: getPageTranslations("bg", "notFound"),
  en: getPageTranslations("en", "notFound"),
} as const;

const defaultLanguage = "bg";
const defaultTranslation = translations.bg;
---

<Layout language={defaultLanguage} pageKey="notFound">
  <main class="min-h-[calc(100vh-var(--header-height))] bg-site">
    <section
      class="site-container flex min-h-[70vh] items-center justify-center py-20 sm:py-24 lg:py-28"
    >
      <div class="mx-auto max-w-6xl text-center">
        <p
          class="font-inter text-sm font-semibold uppercase tracking-[0.32em] text-text-muted"
        >
          404
        </p>

        <h1
          id="notfound-title"
          class="mt-5 whitespace-nowrap font-libertinus text-[clamp(1.75rem,4.8vw,5rem)] font-bold leading-[1.04] tracking-tight text-text-"
        >
          {defaultTranslation.title}
        </h1>

        <div class="section-divider mx-auto mt-6 max-w-md"></div>

        <p
          id="notfound-description"
          class="mx-auto mt-7 max-w-5xl whitespace-nowrap font-inter text-[clamp(0.95rem,1.6vw,1.25rem)] font-medium leading-relaxed text-text-secondary"
        >
          {defaultTranslation.description}
        </p>

        <div class="mt-9 flex justify-center">
          <a id="notfound-home-link" href="/" class="button-primary">
            {defaultTranslation.homeButtonText}
          </a>
        </div>
      </div>
    </section>
  </main>

  <script
    is:inline
    id="notfound-translations"
    type="application/json"
    set:html={JSON.stringify(translations)}
  />

  <script is:inline>
    const raw =
      document.getElementById("notfound-translations")?.textContent ?? "{}";
    const translations = JSON.parse(raw);

    const pathname = window.location.pathname;
    const isEnglish = pathname === "/en" || pathname.startsWith("/en/");
    const translation = isEnglish ? translations.en : translations.bg;

    document.documentElement.lang = isEnglish ? "en" : "bg";
    document.title = translation.browserTitle;

    const titleElement = document.getElementById("notfound-title");
    const descriptionElement = document.getElementById("notfound-description");
    const homeLinkElement = document.getElementById("notfound-home-link");

    if (titleElement) {
      titleElement.textContent = translation.title;
    }

    if (descriptionElement) {
      descriptionElement.textContent = translation.description;
    }

    if (homeLinkElement) {
      homeLinkElement.textContent = translation.homeButtonText;
      homeLinkElement.setAttribute("href", isEnglish ? "/en" : "/");
    }
  </script>
</Layout>