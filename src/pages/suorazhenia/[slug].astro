---
import { getCollection } from "astro:content";
import FacilityPage from "../../templates/facilities/FacilityPage.astro";

export async function getStaticPaths() {
  const facilities = await getCollection("facilities", ({ data }) => {
    return data.language === "bg";
  });

  return facilities.map((facility) => ({
    params: {
      slug: facility.data.slug,
    },
    props: {
      facility,
    },
  }));
}

const { facility } = Astro.props;
---

<FacilityPage facility={facility} language="bg" />