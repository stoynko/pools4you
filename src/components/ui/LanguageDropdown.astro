---
import type { PageKey } from "../../config/pages/pageDefinitions.ts";
import type { Language } from "../../config/i18n/i18n.ts";

import { getPagePath } from "../../config/pages/pagePaths.ts";

const { language, pageKey } = Astro.props as {
  language: Language;
  pageKey: PageKey;
};

const bgPath = getPagePath(pageKey, "bg");
const enPath = getPagePath(pageKey, "en");
---

<div class="relative inline-flex h-10 w-14 shrink-0" data-language-dropdown>
  <button
    type="button"
    class="inline-flex h-10 w-14 shrink-0 items-center justify-center gap-1 p-0 leading-none text-text-secondary transition-colors duration-150 hover:text-brand-gold focus-visible:text-brand-gold"
    aria-label={language === "bg" ? "Open language menu" : "Отвори меню за език"}
    aria-haspopup="true"
    aria-expanded="false"
    data-language-dropdown-button
  >
    <svg
      class="h-5 w-5 shrink-0"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M6.23509 6.45329C4.85101 7.89148 4 9.84636 4 12C4 16.4183 7.58172 20 12 20C13.0808 20 14.1116 19.7857 15.0521 19.3972C15.1671 18.6467 14.9148 17.9266 14.8116 17.6746C14.582 17.115 13.8241 16.1582 12.5589 14.8308C12.2212 14.4758 12.2429 14.2035 12.3636 13.3943L12.3775 13.3029C12.4595 12.7486 12.5971 12.4209 14.4622 12.1248C15.4097 11.9746 15.6589 12.3533 16.0043 12.8777C16.0425 12.9358 16.0807 12.9928 16.1198 13.0499C16.4479 13.5297 16.691 13.6394 17.0582 13.8064C17.2227 13.881 17.428 13.9751 17.7031 14.1314C18.3551 14.504 18.3551 14.9247 18.3551 15.8472V15.9518C18.3551 16.3434 18.3168 16.6872 18.2566 16.9859C19.3478 15.6185 20 13.8854 20 12C20 8.70089 18.003 5.8682 15.1519 4.64482C14.5987 5.01813 13.8398 5.54726 13.575 5.91C13.4396 6.09538 13.2482 7.04166 12.6257 7.11976C12.4626 7.14023 12.2438 7.12589 12.012 7.11097C11.3905 7.07058 10.5402 7.01606 10.268 7.75495C10.0952 8.2232 10.0648 9.49445 10.6239 10.1543C10.7134 10.2597 10.7307 10.4547 10.6699 10.6735C10.59 10.9608 10.4286 11.1356 10.3783 11.1717C10.2819 11.1163 10.0896 10.8931 9.95938 10.7412C9.64554 10.3765 9.25405 9.92233 8.74797 9.78176C8.56395 9.73083 8.36166 9.68867 8.16548 9.64736C7.6164 9.53227 6.99443 9.40134 6.84992 9.09302C6.74442 8.8672 6.74488 8.55621 6.74529 8.22764C6.74529 7.8112 6.74529 7.34029 6.74529 6.88256C6.46246 6.70541 6.35689 6.56446 6.23509 6.45329ZM12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22Z" />
    </svg>

    <svg
      class="h-4 w-4 shrink-0"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M12 15.0006L7.75732 10.758L9.17154 9.34375L12 12.1722L14.8284 9.34375L16.2426 10.758L12 15.0006Z" />
    </svg>
  </button>

  <div
    class="absolute right-0 top-full z-50 mt-2 hidden w-24 overflow-hidden rounded-button border border-border bg-site shadow-lg"
    data-language-dropdown-menu
  >
    <a
      href={enPath}
      class:list={[
        "flex h-9 items-center justify-center font-inter text-sm font-medium transition-colors duration-150 hover:bg-brand-goldSubtle hover:text-brand-gold",
        { "text-brand-gold": language === "en", "text-text-secondary": language !== "en" },
      ]}
    >
      EN
    </a>

    <a
      href={bgPath}
      class:list={[
        "flex h-9 items-center justify-center font-inter text-sm font-medium transition-colors duration-150 hover:bg-brand-goldSubtle hover:text-brand-gold",
        { "text-brand-gold": language === "bg", "text-text-secondary": language !== "bg" },
      ]}
    >
      BG
    </a>
  </div>
</div>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) return;

    const dropdowns = document.querySelectorAll("[data-language-dropdown]");

    dropdowns.forEach((dropdown) => {
      const button = dropdown.querySelector("[data-language-dropdown-button]");
      const menu = dropdown.querySelector("[data-language-dropdown-menu]");

      if (!(button instanceof HTMLElement)) return;
      if (!(menu instanceof HTMLElement)) return;

      const clickedButton = button.contains(target);
      const clickedInside = dropdown.contains(target);

      if (clickedButton) {
        const isOpen = !menu.classList.contains("hidden");

        menu.classList.toggle("hidden", isOpen);
        button.setAttribute("aria-expanded", String(!isOpen));

        return;
      }

      if (!clickedInside) {
        menu.classList.add("hidden");
        button.setAttribute("aria-expanded", "false");
      }
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;

    document.querySelectorAll("[data-language-dropdown]").forEach((dropdown) => {
      const button = dropdown.querySelector("[data-language-dropdown-button]");
      const menu = dropdown.querySelector("[data-language-dropdown-menu]");

      if (!(button instanceof HTMLElement)) return;
      if (!(menu instanceof HTMLElement)) return;

      menu.classList.add("hidden");
      button.setAttribute("aria-expanded", "false");
    });
  });
</script>