---
import type { Language } from "../../config/i18n/i18n.ts";
import { getPagePath } from "../../config/pages/pagePaths.ts";
import { getPageTranslations } from "../../lib/i18n";
import FooterLogo from "../brand/FooterLogo.astro";

const { language } = Astro.props as {
  language: Language;
};

const translation = getPageTranslations(language, "footer");

const homePath = getPagePath("home", language);
const servicesPath = getPagePath("services", language);
const projectsPath = getPagePath("projects", language);
const facilitiesPath = getPagePath("facilities", language);
const aboutPath = getPagePath("about", language);

const fallbackPath = homePath;
const facebookUrl = import.meta.env.PUBLIC_FACEBOOK_URL || fallbackPath;
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL || fallbackPath;
const tiktokUrl = import.meta.env.PUBLIC_TIKTOK_URL || fallbackPath;

const socialLinks = [
  {
    label: "Facebook",
    href: facebookUrl,
    icon: "facebook",
  },
  {
    label: "Instagram",
    href: instagramUrl,
    icon: "instagram",
  },
  {
    label: "TikTok",
    href: tiktokUrl,
    icon: "tiktok",
  },
] as const;
---

<footer class="site-footer">
  <div class="footer-brand-shell">
    <div class="footer-brand-row">
      <FooterLogo />
      <div class="footer-brand-divider"></div>
    </div>
  </div>

  <div class="footer-inner">
    <div class="footer-columns">
      <div>
        <h3 class="footer-heading">
          {translation.categoryServices}
        </h3>

        <ul class="space-y-2.5">
          <li>
            <a
              href={servicesPath}
              data-label={translation.subServicesDesign}
              class="footer-link-effect"
            >
              {translation.subServicesDesign}
            </a>
          </li>
          <li>
            <a
              href={servicesPath}
              data-label={translation.subServicesConstruction}
              class="footer-link-effect"
            >
              {translation.subServicesConstruction}
            </a>
          </li>
          <li>
            <a
              href={servicesPath}
              data-label={translation.subServicesRenovation}
              class="footer-link-effect"
            >
              {translation.subServicesRenovation}
            </a>
          </li>
          <li>
            <a
              href={servicesPath}
              data-label={translation.subServicesMaintenance}
              class="footer-link-effect"
            >
              {translation.subServicesMaintenance}
            </a>
          </li>
          <li>
            <a
              href={servicesPath}
              data-label={translation.subServicesConsulting}
              class="footer-link-effect"
            >
              {translation.subServicesConsulting}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">
          {translation.categorySolutions}
        </h3>

        <ul class="space-y-2.5">
          <li>
            <a
              href={facilitiesPath}
              data-label={translation.subSolutionsPools}
              class="footer-link-effect"
            >
              {translation.subSolutionsPools}
            </a>
          </li>
          <li>
            <a
              href={facilitiesPath}
              data-label={translation.subSolutionsSpa}
              class="footer-link-effect"
            >
              {translation.subSolutionsSpa}
            </a>
          </li>
          <li>
            <a
              href={facilitiesPath}
              data-label={translation.subSolutionsSaunas}
              class="footer-link-effect"
            >
              {translation.subSolutionsSaunas}
            </a>
          </li>
          <li>
            <a
              href={facilitiesPath}
              data-label={translation.subSolutionsAquaparks}
              class="footer-link-effect"
            >
              {translation.subSolutionsAquaparks}
            </a>
          </li>
          <li>
            
          </li>
          <li>
            <a
              href={facilitiesPath}
              data-label={translation.subSolutionsTechnical}
              class="footer-link-effect"
            >
              {translation.subSolutionsTechnical}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">
          {translation.categoryProjects}
        </h3>

        <ul class="space-y-2.5">
          <li>
            <a
              href={projectsPath}
              data-label={translation.subProjectsHospitality}
              class="footer-link-effect"
            >
              {translation.subProjectsHospitality}
            </a>
          </li>
          <li>
            <a
              href={projectsPath}
              data-label={translation.subProjectsPublic}
              class="footer-link-effect"
            >
              {translation.subProjectsPublic}
            </a>
          </li>
          <li>
            <a
              href={projectsPath}
              data-label={translation.subProjectsPrivate}
              class="footer-link-effect"
            >
              {translation.subProjectsPrivate}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">
          {translation.categoryCompany}
        </h3>

        <ul class="space-y-2.5">
          <li>
            <a
              href={aboutPath}
              data-label={translation.subCompanyAbout}
              class="footer-link-effect"
            >
              {translation.subCompanyAbout}
            </a>
          </li>
          <li>
            <a
              href={fallbackPath}
              data-label={translation.subCompanyContacts}
              class="footer-link-effect"
            >
              {translation.subCompanyContacts}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-social-row">
      <div class="footer-social-divider"></div>

      <div class="footer-socials" aria-label="Social links">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              class="footer-social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
            >
              {social.icon === "facebook" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12.001 2C6.47813 2 2.00098 6.47715 2.00098 12C2.00098 16.9913 5.65783 21.1283 10.4385 21.8785V14.8906H7.89941V12H10.4385V9.79688C10.4385 7.29063 11.9314 5.90625 14.2156 5.90625C15.3097 5.90625 16.4541 6.10156 16.4541 6.10156V8.5625H15.1931C13.9509 8.5625 13.5635 9.33334 13.5635 10.1242V12H16.3369L15.8936 14.8906H13.5635V21.8785C18.3441 21.1283 22.001 16.9913 22.001 12C22.001 6.47715 17.5238 2 12.001 2Z" />
                </svg>
              )}

              {social.icon === "instagram" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.25-2.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Z" />
                </svg>
              )}

              {social.icon === "tiktok" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M16 8.24537V15.5C16 19.0899 13.0899 22 9.5 22C5.91015 22 3 19.0899 3 15.5C3 11.9101 5.91015 9 9.5 9C10.0163 9 10.5185 9.06019 11 9.17393V12.3368C10.5454 12.1208 10.0368 12 9.5 12C7.567 12 6 13.567 6 15.5C6 17.433 7.567 19 9.5 19C11.433 19 13 17.433 13 15.5V2H16C16 4.76142 18.2386 7 21 7V10C19.1081 10 17.3696 9.34328 16 8.24537Z" />
                </svg>
              )}
            </a>
          ))
        }
      </div>

      <div class="footer-social-divider"></div>
    </div>

    <div class="footer-legal">
      <div class="space-y-1 text-center">
        <p>
          © 2026 Pools 4 You LTD. {translation.rightsReserved} |
          <a
            href={fallbackPath}
            data-label={translation.terms}
            class="footer-link-effect"
          >
            {translation.terms}
          </a>
          |
          <a
            href={fallbackPath}
            data-label={translation.privacy}
            class="footer-link-effect"
          >
            {translation.privacy}
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
