---
import type { PageKey } from "../../config/pages/pageRegistry.ts";
import type { Language } from "../../config/i18n/i18n.ts";
import { getPagePath } from "../../config/pages/helpers.ts";
import { getPageTranslations } from "../../lib/i18n";
import { primaryNav } from "../../config/navigation/navigationItems";
import HeaderLink from "./HeaderLink.astro";

const { language, pageKey } = Astro.props as {
  language: Language;
  pageKey: PageKey;
};

const translation = getPageTranslations(language, "header");
---

<header class="border-b border-gray-800">
  <div class="max-w-6xl mx-auto flex justify-between items-center p-6">
    
    <!-- LOGO -->
    <a href={getPagePath("home", language)}
       class="font-libertinus text-2xl font-semibold text-blue-400">
      Pools4You
    </a>

    <!-- NAVIGATION -->
    <nav class="flex items-center gap-6" aria-label="Main navigation">
      {primaryNav.map((key) => (
        <HeaderLink
          href={getPagePath(key, language)}
          label={translation[key]}
          isActive={pageKey === key}
        />
      ))}
    </nav>

  </div>
</header>