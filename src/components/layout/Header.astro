---
import type { PageKey } from "../../config/pages/pageDefinitions.ts";
import type { Language } from "../../config/i18n/i18n.ts";

import { getPagePath } from "../../config/pages/pagePaths.ts";
import { getPageTranslations } from "../../lib/i18n";
import { primaryNav } from "../../config/navigation/navigationItems";

// Components
import HeaderLink from "./HeaderLink.astro";
import HeaderLogo from "../brand/HeaderLogo.astro";
import HeaderMobileMenu from "./HeaderMobileMenu.astro";
import ThemeToggleIcon from "../ui/ThemeToggle.astro";
import LanguageDropdown from "../ui/LanguageDropdown.astro";

const { language, pageKey } = Astro.props as {
  language: Language;
  pageKey: PageKey;
};

const translation = getPageTranslations(language, "header");
---

<header class="bg-site text-text border-b border-border">
  <div
    class="site-container grid h-header grid-cols-[auto_1fr_auto] items-center gap-6 lg:grid-cols-[240px_minmax(0,1fr)_300px] xl:gap-8"
  >
    <!-- LEFT: LOGO -->
    <div class="col-start-1 flex items-center justify-self-start">
      <HeaderLogo language={language} />
    </div>

    <!-- CENTER: DESKTOP NAV -->
    <nav
      class="col-start-2 hidden min-w-0 items-center justify-start gap-4 overflow-hidden pl-10 lg:flex xl:gap-8 xl:pl-14"
      aria-label="Main navigation"
    >
      {
        primaryNav.map((key) => (
          <HeaderLink
            href={getPagePath(key, language)}
            label={translation[key]}
            isActive={pageKey === key}
          />
        ))
      }
    </nav>

    <!-- RIGHT: DESKTOP ACTIONS -->
    <div
      class="col-start-3 hidden w-[300px] shrink-0 items-center justify-end gap-3 lg:flex"
      aria-label="Header actions"
    >
      <button
        type="button"
        data-theme-toggle
        class="group inline-flex h-10 w-10 shrink-0 items-center justify-center p-0 leading-none text-text-secondary transition-colors duration-150 hover:text-brand-gold focus-visible:text-brand-gold"
        aria-label="Theme Toggle"
      >
        <ThemeToggleIcon />
      </button>

      <LanguageDropdown language={language} pageKey={pageKey} />

      <a
        href={getPagePath("services", language)}
        class="button-primary w-header-cta shrink-0 whitespace-nowrap"
      >
        {translation.enquire}
      </a>
    </div>

    <!-- MOBILE HAMBURGER -->
    <div class="col-start-3 flex items-center justify-end lg:hidden">
      <HeaderMobileMenu language={language} pageKey={pageKey} />
    </div>
  </div>
</header>