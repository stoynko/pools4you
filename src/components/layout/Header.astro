---
import type { PageKey } from "../../config/pages/pageDefinitions.ts";
import type { Language } from "../../config/i18n/i18n.ts";
import { getPagePath } from "../../config/pages/pagePaths.ts";
import { getPageTranslations } from "../../lib/i18n";
import { primaryNav } from "../../config/navigation/navigationItems";
import HeaderLink from "./HeaderLink.astro";
import HeaderLogo from "../brand/HeaderLogo.astro";

const { language, pageKey } = Astro.props as {
  language: Language;
  pageKey: PageKey;
};

const translation = getPageTranslations(language, "header");
---

<header class="border-b border-border bg-site text-text">

  <div class="site-container flex min-h-header items-center justify-between">
    
    <!-- LOGO -->
    <HeaderLogo language={language} />

    <!-- NAVIGATION -->
    <nav class="flex items-center gap-6" aria-label="Main navigation">
      {
        primaryNav.map((key) => (
          <HeaderLink
            href={getPagePath(key, language)}
            label={translation[key]}
            isActive={pageKey === key}
          />
        ))
      }
    </nav>

    <!-- HEADER ACTIONS -->
    <div class="flex items-center gap-3">
      <button
        type="button"
        data-theme-toggle
        class="inline-flex h-10 w-10 items-center justify-center rounded border border-border bg-transparent text-sm text-text transition hover:border-brand-gold hover:text-brand-gold"
        aria-label="Toggle dark mode"
      >
        ◐
      </button>
    </div>
  </div>
</header>
