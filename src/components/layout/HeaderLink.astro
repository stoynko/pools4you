---
const { href, label, isActive } = Astro.props as {
  href: string;
  label: string;
  isActive: boolean;
};

const linkClass = isActive
  ? "text-white font-semibold underline underline-offset-4 decoration-2"
  : "text-gray-300 hover:text-white transition";
---

<a href={href} aria-current={isActive ? "page" : undefined} class={linkClass}> {label} </a>