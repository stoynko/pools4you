---
const { href, label, isActive = false } = Astro.props as {
  href: string;
  label: string;
  isActive?: boolean;
};

const activeLinkClass = isActive
  ? "font-semibold underline underline-offset-4 decoration-2"
  : "transition";
---

<a
  href={href}
  class={activeLinkClass}
  style={`color: ${isActive ? "var(--color-gold)" : "var(--color-text-secondary)"}; text-decoration-color: var(--color-gold);`}
  aria-current={isActive ? "page" : undefined}
>
  {label}
</a>