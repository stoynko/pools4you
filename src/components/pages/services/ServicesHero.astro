---
import { Image } from "astro:assets";
import heroImage from "../../../assets/images/pages/home/hero.png";

import type { Language } from "../../../config/i18n/i18n";
import { getPageTranslations } from "../../../lib/i18n";

type Props = {
  language: Language;
};

const { language } = Astro.props as Props;

const translation = getPageTranslations(language, "services");
const imageAlt = "Luxury swimming pool";
---

<section class="hero-section hero-section-full">
  <Image
    src={heroImage}
    alt={imageAlt}
    class="hero-image object-[50%_48%]"
    widths={[640, 960, 1280, 1600, 1920, 2400]}
    sizes="100vw"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <div class="hero-image-overlay"></div>

  <div aria-hidden="true" class="hero-fade-top"></div>

  <div aria-hidden="true" class="hero-fade-bottom"></div>

  <div class="hero-container hero-container-full">
    <div class="hero-blur-panel">
      
      <h1 class="hero-title">
        {translation.hero.title}
      </h1>

   
    </div>
  </div>
</section>