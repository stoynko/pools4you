---
import type { Language } from "../../../config/i18n/i18n";
import { getPageTranslations } from "../../../lib/i18n";

import SectionHeader from "../../shared/SectionHeader.astro";

type Props = {
  language: Language;
};

const { language } = Astro.props as Props;

const translation = getPageTranslations(language, "services");
---

<section class="section-shell section-spacing-md bg-site-warm">
  <div class="section-container">

    <SectionHeader
      title={translation.why.title}
      description={translation.why.text}
    />

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        translation.why.proof.map((item) => (
          <article class="min-h-60 border border-border bg-site-surface p-7 transition-colors duration-200 hover:border-brand-gold">
            <h3 class="font-libertinus text-2xl font-semibold leading-tight text-text">
              {item.title}
            </h3>

            <p class="mt-4 font-inter text-[0.95rem] leading-relaxed text-text-secondary">
              {item.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>

  
</section>