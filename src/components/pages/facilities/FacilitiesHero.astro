---
import type { CollectionEntry } from "astro:content";
import PageHero from "../../shared/PageHero.astro";

type FacilitiesPageEntry = CollectionEntry<"facilitiesPages">;

type Props = {
  page: FacilitiesPageEntry;
};

const { page } = Astro.props as Props;
---

<PageHero
  title={page.data.title}
  body={page.data.description}
  benefits={page.data.benefits}
  align="left"
  divider="short"
/>