---
import PageHero from "../../shared/PageHero.astro";

type Props = {
  translation: {
    title: string;
    description: string;
    benefits: readonly string[];
  };
};

const { translation } = Astro.props as Props;
---

<PageHero
  title={translation.title}
  body={translation.description}
  benefits={translation.benefits}
  align="left"
  divider="short"
/>