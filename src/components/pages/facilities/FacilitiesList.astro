---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { Language } from "../../../config/i18n/i18n";
import { getFacilityImage } from "../../../lib/facilities/facilityImages";

type FacilityEntry = CollectionEntry<"facilities">;

type Props = {
  language: Language;
  facilities: FacilityEntry[];
};

const { language, facilities } = Astro.props as Props;

function getFacilityHref(facility: FacilityEntry) {
  if (language === "bg") {
    return `/suorazhenia/${facility.data.slug}`;
  }

  return `/en/facilities/${facility.data.slug}`;
}

function getFacilityTitle(facility: FacilityEntry) {
  return facility.data.cardTitle ?? facility.data.title;
}

function getFacilityDescription(facility: FacilityEntry) {
  return facility.data.description;
}

function getFacilityCardImage(facility: FacilityEntry) {
  return getFacilityImage(
    facility.data.translationKey,
    facility.data.heroImageKey,
  );
}

const sectionTitle = language === "bg" ? "Видове съоръжения" : "Facility Types";

const viewLabel = language === "bg" ? "Разгледай" : "View";
---

{
  facilities.length > 0 && (
    <section
      class="facilities-vertical section"
      aria-labelledby="facilities-vertical-title"
    >
      <div class="site-container-wide">
        <header class="facilities-card-header">
          <div>
            <h2 id="facilities-vertical-title">{sectionTitle}</h2>
          </div>
        </header>

        <div class="facilities-vertical__list">
          {facilities.map((facility) => {
            const cardImage = getFacilityCardImage(facility);

            return (
              <article class="facilities-vertical-card">
                <a
                  href={getFacilityHref(facility)}
                  class="facilities-vertical-card__link"
                >
                  <div
                    class:list={[
                      "facilities-vertical-card__visual",
                      cardImage &&
                        "facilities-vertical-card__visual--has-image",
                    ]}
                  >
                    {cardImage && (
                      <Image
                        src={cardImage}
                        alt={facility.data.heroImageAlt ?? facility.data.title}
                        class={`facilities-vertical-card__image ${facility.data.heroImagePosition ?? ""}`}
                        loading="lazy"
                      />
                    )}
                  </div>

                  <div class="facilities-vertical-card__content">
                    <h3>{getFacilityTitle(facility)}</h3>

                    <p>{getFacilityDescription(facility)}</p>

                    <span class="facilities-vertical-card__cta">
                      {viewLabel} →
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}
