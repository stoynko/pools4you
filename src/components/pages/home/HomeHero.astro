---
import type { Language } from "../../../config/i18n/i18n";
import { getPageTranslations } from "../../../lib/i18n";

import PageHero from "../../shared/PageHero.astro";
import heroImage from "../../../assets/images/pages/home/hero.png";

type Props = {
  language: Language;
};

const { language } = Astro.props as Props;

const translation = getPageTranslations(language, "home");
const imageAlt = "Luxury swimming pool";
---

<PageHero
  title={translation.hero.title}
  body={translation.hero.subtitle}
  image={heroImage}
  imageAlt="Luxury swimming pool"
  imagePositionClass="object-[50%_48%]"
  frostedPanel={false}
  divider="none"
/>
