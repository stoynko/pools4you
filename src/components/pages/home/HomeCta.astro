---
import type { Language } from "../../../config/i18n/i18n";
import { getPageTranslations } from "../../../lib/i18n";
import { mailTo } from "../../../lib/i18n/contact/mailing";

type Props = {
  language: Language;
};

const { language } = Astro.props as Props;
const translation = getPageTranslations(language, "home");

const contactEmailAddress = import.meta.env.PUBLIC_CONTACT_EMAIL;
const contactHref = mailTo(contactEmailAddress, {
  subject: translation.cta.emailSubject,
});
---

<section class="home-cta-section">
  <div class="site-container">
    <div class="section-divider mb-16 sm:mb-20 lg:mb-24"></div>

    <div class="home-cta-panel">
      <div class="home-cta-icon" aria-hidden="true">
        <div class="home-cta-icon" aria-hidden="true">
          <img
            src="/images/brand/pools4you-logo-icon-black.svg"
            alt="Waterdrop"
            class="home-cta-logo home-cta-logo-light"
            loading="lazy"
            decoding="async"
          />

          <img
            src="/images/brand/pools4you-logo-icon-color.svg"
            alt="Waterdrop"
            class="home-cta-logo home-cta-logo-dark"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <h2 class="home-cta-title">{translation.cta.title}</h2>

      <p class="home-cta-body">
        {translation.cta.body}
      </p>

      <div class="home-cta-actions">
        <a href={contactHref} class="button-primary home-cta-button">
          {translation.cta.primaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
