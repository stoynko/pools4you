---
import type { Language } from "../../../config/i18n/i18n";
import { getPageTranslations } from "../../../lib/i18n";
import Image from "astro/components/Image.astro";
import poolImage from "../../../assets/images/pages/home/pool.png";
import HomeProcessItem from "./HomeProcessItem.astro";

const { language } = Astro.props as {
  language: Language;
};

const translation = getPageTranslations(language, "home");
---

<section class="section-shell section-spacing-lg">
  <div class="section-container">
    <div class="w-full">
      <h2 class="section-title-lg">
        {translation.vision.title}
      </h2>

      <div class="section-divider"></div>

      <div class="section-body-stack">
        <p class="section-body-lg">
          {translation.vision.introMain}
        </p>

        <p class="section-body-lg">
          {translation.vision.introSecondary}
        </p>
      </div>
    </div>

    <div class="split-grid split-grid-spaced">
      <div class="relative">
        <Image
          src={poolImage}
          alt="alt"
          width={poolImage.width}
          height={poolImage.height}
          loading="lazy"
          class="media-card media-card-portrait"
        />
      </div>

      <div class="space-y-20">
        {
          translation.vision.accents.map((accent) => (
            <HomeProcessItem
              id={accent.id}
              title={accent.title}
              body={accent.body}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>