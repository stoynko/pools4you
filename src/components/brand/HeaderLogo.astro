---
import type { Language } from "../../config/i18n/i18n.ts";
import { getPagePath } from "../../config/pages/pagePaths.ts";

const { language, variant = "adaptive" } = Astro.props as {
  language: Language;
  variant?: "adaptive" | "gold" | "black";
};

const homePath = getPagePath("home", language);
---

<a href={homePath} class="site-logo" aria-label="Pools4You home">
  {
    variant === "adaptive" && (
      <>
        <img
          src="/images/brand/pools4you-logo-text-black.svg"
          alt="Pools4You Ltd."
          class="site-logo-image site-logo-image-light"
          loading="eager"
          decoding="async"
        />

        <img
          src="/images/brand/pools4you-logo-text-color.svg"
          alt=""
          class="site-logo-image site-logo-image-dark"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
      </>
    )
  }

  {
    variant === "black" && (
      <img
        src="/images/brand/pools4you-logo-text-black.svg"
        alt="Pools4You Ltd."
        class="site-logo-image"
        loading="eager"
        decoding="async"
      />
    )
  }

  {
    variant === "gold" && (
      <img
        src="/images/brand/pools4you-logo-text-color.svg"
        alt="Pools4You Ltd."
        class="site-logo-image"
        loading="eager"
        decoding="async"
      />
    )
  }
</a>