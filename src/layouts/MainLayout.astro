---
import "../styles/global.css";
import Head from "./MainHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";
import type { PageSeo } from "../config/pages/pageTypes";

const { language, pageKey, seo, alternates } = Astro.props as {
  language: Language;
  pageKey: PageKey;
  seo?: Partial<PageSeo>;
  alternates?: Partial<Record<Language, string>>;
};
---

<html lang={language}>
  <Head language={language} pageKey={pageKey} seo={seo} />

  <script is:inline>
    const storedTheme = localStorage.getItem("theme");
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;

    if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
      document.documentElement.setAttribute("data-theme", "dark");
    }

    document.addEventListener("click", (event) => {
      const toggle = event.target.closest("[data-theme-toggle]");

      if (!toggle) {
        return;
      }

      const isDark =
        document.documentElement.getAttribute("data-theme") === "dark";

      if (isDark) {
        document.documentElement.removeAttribute("data-theme");
        localStorage.setItem("theme", "light");
      } else {
        document.documentElement.setAttribute("data-theme", "dark");
        localStorage.setItem("theme", "dark");
      }
    });
  </script>

  <body class="font-inter">
    <Header language={language} pageKey={pageKey} />
    <slot />
    <Footer language={language} pageKey={pageKey} alternates={alternates} />
  </body>
</html>
