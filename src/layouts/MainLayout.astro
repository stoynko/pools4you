---
import "../styles/global.css";
import Head from "./MainHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";
import type { PageSeo } from "../config/pages/pageTypes";

const { language, pageKey, seo, alternates } = Astro.props as {
  language: Language;
  pageKey: PageKey;
  seo?: Partial<PageSeo>;
  alternates?: Partial<Record<Language, string>>;
};
---

<html lang={language}>

  <Head language={language} pageKey={pageKey} seo={seo} />

  <script>
  const rootElement = document.documentElement;

  const getStoredTheme = () => {
    try {
      return localStorage.getItem("theme");
    } catch {
      return null;
    }
  };

  const setStoredTheme = (theme: "light" | "dark") => {
    try {
      localStorage.setItem("theme", theme);
    } catch { }
  };

  const prefersDark =
    window.matchMedia?.("(prefers-color-scheme: dark)").matches ?? false;

  const storedTheme = getStoredTheme();

  if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
    rootElement.setAttribute("data-theme", "dark");
  }

  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const toggle = target.closest("[data-theme-toggle]");

    if (!(toggle instanceof HTMLElement)) {
      return;
    }

    const isDark = rootElement.getAttribute("data-theme") === "dark";

    if (isDark) {
      rootElement.removeAttribute("data-theme");
      setStoredTheme("light");
      return;
    }

    rootElement.setAttribute("data-theme", "dark");
    setStoredTheme("dark");
  });
</script>

  <body class="font-inter">
    <Header language={language} pageKey={pageKey} alternates={alternates} />
    <slot />
    <Footer language={language} pageKey={pageKey} alternates={alternates} />
  </body>
</html>
