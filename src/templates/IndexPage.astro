---
import Layout from "../layouts/MainLayout.astro";

import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";

import HomeHero from "../components/pages/home/HomeHero.astro";
import HomeVision from "../components/pages/home/HomeVision.astro"
import HomeServices from "../components/pages/home/HomeServices.astro";
import HomeProjects from "../components/pages/home/HomeProjects.astro";
import HomeCta from "../components/pages/home/HomeCta.astro";

type Props = {
  language: Language;
  pageKey: PageKey;
};

const { language, pageKey } = Astro.props as Props;
---

<Layout language={language} pageKey={pageKey}>
  
  <HomeHero language={language} />

  <HomeVision language={language} />

  <HomeServices language={language} />

  <HomeProjects language={language} limit={2}/>

  <HomeCta language={language} />
  
</Layout>