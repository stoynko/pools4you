---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/shared/PageHero.astro";
import SectionHeader from "../../components/shared/SectionHeader.astro";
import FacilityFeatureCards from "../../components/pages/facilities/FacilityFeatureCard.astro";
import type { Language } from "../../config/i18n/i18n";
import { getFacilityImage } from "../../lib/facilities/facilityImages";

type FacilityEntry = CollectionEntry<"facilities">;

const { facility, language } = Astro.props as {
  facility: FacilityEntry;
  language: Language;
};

const translatedFacilities = await getCollection("facilities", ({ data }) => {
  return data.translationKey === facility.data.translationKey;
});

const bgFacility = translatedFacilities.find((entry) => {
  return entry.data.language === "bg";
});

const enFacility = translatedFacilities.find((entry) => {
  return entry.data.language === "en";
});

function getFacilityHref(entry: FacilityEntry) {
  if (entry.data.language === "bg") {
    return `/suorazhenia/${entry.data.slug}`;
  }

  return `/en/facilities/${entry.data.slug}`;
}

const alternates = {
  bg: bgFacility ? getFacilityHref(bgFacility) : undefined,
  en: enFacility ? getFacilityHref(enFacility) : undefined,
};

const canonical = getFacilityHref(facility);

const pageSeo = {
  title: facility.data.seoTitle ?? `${facility.data.title} | Pools4You`,
  description: facility.data.seoDescription ?? facility.data.description,
  canonical,
  alternates,
};

const heroImage = getFacilityImage(
  facility.data.translationKey,
  facility.data.heroImageKey,
);

const { Content } = await render(facility);

const hasContentSections = facility.data.contentSections.length > 0;
---

<MainLayout
  language={language}
  pageKey="facilities"
  seo={pageSeo}
  alternates={alternates}
>
  <main class="facility-page">
    <PageHero
      title={facility.data.title}
      body={facility.data.description}
      image={heroImage}
      imageAlt={facility.data.heroImageAlt ?? facility.data.title}
      imagePositionClass={facility.data.heroImagePosition}
      align="left"
      divider="short"
      frostedPanel={Boolean(heroImage)}
    />

    {
      hasContentSections && (
        <section class="facility-section facility-section--content-sections">
          <div class="facility-container facility-content-sections">
            {facility.data.contentSections.map((section) => {
              if (section.type === "cards") {
                return (
                  facility.data.featureCards.length > 0 && (
                    <section class="facility-content-block facility-content-block--cards">
                      <SectionHeader title={section.title} />

                      <FacilityFeatureCards
                        facilityKey={facility.data.translationKey}
                        cards={facility.data.featureCards}
                      />
                    </section>
                  )
                );
              }

              return (
                <section class="facility-content-block facility-content-block--text">
                  <SectionHeader title={section.title} />

                  {section.text && (
                    <p class="facility-content-text">
                      {section.text}
                    </p>
                  )}
                </section>
              );
            })}
          </div>
        </section>
      )
    }

    {
      !hasContentSections && (
        <>
          {
            facility.data.featureCards.length > 0 && (
              <section class="facility-section facility-section--cards">
                <div class="facility-container">
                  <SectionHeader title={facility.data.title} />

                  <FacilityFeatureCards
                    facilityKey={facility.data.translationKey}
                    cards={facility.data.featureCards}
                  />
                </div>
              </section>
            )
          }

          <section class="facility-section facility-section--content">
            <div class="facility-container facility-content-container">
              <article class="facility-content">
                <Content />
              </article>
            </div>
          </section>
        </>
      )
    }
  </main>
</MainLayout>