---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../layouts/MainLayout.astro";
import { getPageTranslations } from "../lib/i18n";
import { Image } from "astro:assets";
import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";

type Props = {
  language: Language;
  pageKey: PageKey;
};

type ProjectEntry = CollectionEntry<"projects">;

const { language, pageKey } = Astro.props as Props;

const translation = getPageTranslations(language, "projects");

const projects = await getCollection("projects", ({ data }) => {
  return data.language === language;
});

const sortedProjects = projects.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

function getProjectHref(project: ProjectEntry) {
  if (language === "bg") {
    return `/proekti/${project.data.slug}`;
  }

  return `/en/projects/${project.data.slug}`;
}
---

<Layout language={language} pageKey={pageKey}>
  <main>
    <section class="mx-auto max-w-6xl px-6 py-20">
      <header class="mb-12 max-w-3xl">
        <h1 class="mb-6 text-5xl font-libertinus font-bold leading-tight">
          {translation.hero.title}
        </h1>

        <p class="text-lg leading-relaxed text-gray-300">
          {translation.hero.subtitle}
        </p>
      </header>

      {
        sortedProjects.length > 0 ? (
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {sortedProjects.map((project) => (
              <article class="overflow-hidden rounded-2xl border border-gray-800 bg-white/5 shadow-xl transition hover:-translate-y-1 hover:border-blue-400/50 hover:bg-white/10">
                <a href={getProjectHref(project)} class="block">
                  <Image
                    src={project.data.thumbnailImage}
                    width={project.data.thumbnailImage.width}
                    height={project.data.thumbnailImage.height}
                    alt={project.data.title}
                    loading="eager"
                    decoding="async"
                    class="h-64 w-full object-cover"
                  />

                  <div class="space-y-4 p-6">
                    <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-gray-400">
                      <span>{project.data.location}</span>
                      <span aria-hidden="true">•</span>
                      <time datetime={project.data.date.toISOString()}>
                        {project.data.date.toLocaleDateString(
                          language === "bg" ? "bg-BG" : "en-GB",
                        )}
                      </time>
                    </div>

                    <h2 class="text-2xl font-libertinus font-semibold text-white">
                      {project.data.title}
                    </h2>

                    <p class="line-clamp-3 leading-relaxed text-gray-300">
                      {project.data.description}
                    </p>

                    <span class="inline-flex text-sm font-semibold text-blue-300">
                      {translation.card.viewProject} →
                    </span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="text-gray-400">{translation.empty}</p>
        )
      }
    </section>
  </main>
</Layout>
