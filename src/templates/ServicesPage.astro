---
import Layout from "../layouts/MainLayout.astro";
import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";

import ServicesHero from "../components/pages/services/ServicesHero.astro";
import ServicesList from "../components/pages/services/ServicesList.astro";
import ServicesWhy from "../components/pages/services/ServicesWhy.astro";

type Props = {
  language: Language;
  pageKey: PageKey;
};

const { language, pageKey } = Astro.props as Props;
---

<Layout language={language} pageKey={pageKey}>

  <ServicesHero language={language} />

  <ServicesList language={language} />

  <ServicesWhy language={language} />

</Layout>
