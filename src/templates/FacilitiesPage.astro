---
import Layout from "../layouts/MainLayout.astro";
import { getPageTranslations } from "../lib/i18n";
import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";

type Props = {
  language: Language;
  pageKey: PageKey;
};

const { language, pageKey } = Astro.props as Props;
const translation = getPageTranslations(language, "home");
---

<Layout language={language} pageKey={pageKey}>

  <section class="max-w-6xl mx-auto px-6 py-20 text-center space-y-6">
    <h1 class="text-6xl font-libertinus font-bold leading-tight">
      Facilities .. coming soon
    </h1>
  </section>

</Layout>
