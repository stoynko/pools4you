---
import { getCollection } from "astro:content";
import Layout from "../layouts/MainLayout.astro";
import type { PageKey } from "../config/pages/pageDefinitions";
import type { Language } from "../config/i18n/i18n";
import { getPageTranslations } from "../lib/i18n";
import { getPagePath } from "../config/pages/pagePaths";

import FacilitiesHero from "../components/pages/facilities/FacilitiesHero.astro";
import FacilitiesIntro from "../components/pages/facilities/FacilitiesIntro.astro";
import FacilitiesList from "../components/pages/facilities/FacilitiesList.astro";

type Props = {
  language: Language;
  pageKey: PageKey;
};

const { language, pageKey } = Astro.props as Props;

const translation = getPageTranslations(language, "facilities");

const facilities = await getCollection("facilities", ({ data }) => {
  return data.language === language;
});

const sortedFacilities = facilities.sort((a, b) => {
  return a.data.order - b.data.order;
});

const canonical = getPagePath("facilities", language);

const pageSeo = {
  title: translation.hero.title,
  description: translation.hero.description,
  canonical,
  alternates: {
    bg: getPagePath("facilities", "bg"),
    en: getPagePath("facilities", "en"),
  },
};
---

<Layout language={language} pageKey={pageKey} seo={pageSeo}>
  <main>
    <FacilitiesHero translation={translation.hero} />
    <FacilitiesIntro translation={translation.intro} />
    <FacilitiesList
      language={language}
      facilities={sortedFacilities}
      translation={translation.list}
    />
  </main>
</Layout>